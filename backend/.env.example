# PPT God can be opened without any model key. Configure these only when you
# want the backend/CLI itself to call models. GUI users can save the same values
# from “模型设置” instead.

# Text generation: any OpenAI Chat Completions compatible provider/model.
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.cometapi.com/v1
MINIMAX_LLM_MODEL=MiniMax-M3

# Image generation: any OpenAI Images compatible provider/model.
COMET_API_KEY=
COMET_API_BASE=https://api.cometapi.com/v1
COMET_IMAGE_MODEL=gpt-image-2
